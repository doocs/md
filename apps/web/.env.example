# 是否在 UI 显示云同步（按钮、菜单）。false 时隐藏入口，后端仍可配置。
VITE_SYNC_UI_ENABLED=false

# 云同步后端地址（@md/sync-worker 部署后的 Worker 域名）。
# 留空则前端不显示云同步入口。
# 本地开发把本文件复制为 .env 并按需修改；
# 生产/预览构建使用已提交的 .env.production（指向官方后端）。
VITE_SYNC_API_URL=http://localhost:8787

# 爱发电创作者主页（Pro 升级跳转），例如 https://ifdian.net/a/doocs
VITE_AFDIAN_PAGE_URL=

# 爱发电下单页域名，与主页保持一致即可
VITE_AFDIAN_ORDER_BASE=https://ifdian.net
