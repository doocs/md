# md-api 后端地址（账户登录、云同步等共用）。可与 VITE_MD_API_URL 二选一。
VITE_SYNC_API_URL=http://localhost:8787

# 是否在 UI 显示账户入口（Footer 登录/账户按钮）。默认：已配置 API 即显示。
# VITE_ACCOUNT_UI_ENABLED=true

# 是否在 UI 显示云同步入口。默认：已配置 API 即显示（可被下方 false 关闭）。
VITE_SYNC_UI_ENABLED=false

# 爱发电创作者主页（Pro 升级跳转），例如 https://ifdian.net/a/doocs
VITE_AFDIAN_PAGE_URL=

# 爱发电下单页域名，与主页保持一致即可
VITE_AFDIAN_ORDER_BASE=https://ifdian.net
