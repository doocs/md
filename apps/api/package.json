{
  "name": "@md/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for doocs/md – Cloudflare Worker (Hono + D1): GitHub OAuth account, cloud sync, and billing",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "db:migrate:local": "wrangler d1 migrations apply md-sync --local",
    "db:migrate:remote": "wrangler d1 migrations apply md-sync --remote",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260711.1",
    "@types/node": "^26.1.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
