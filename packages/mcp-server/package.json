    "dev": "node --import tsx/esm --watch run.mjs"
  },
  "dependencies": {
    "@md/core": "workspace:*",
    "@md/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "~6.0.3"
  }
}
