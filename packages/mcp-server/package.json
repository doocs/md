{
  "name": "@md/mcp-server",
  "type": "module",
  "version": "2.1.1",
  "private": true,
  "description": "MCP server for doocs/md – exposes markdown rendering and AI service information to AI agents",
  "bin": {
    "md-mcp": "src/index.ts"
  },
  "scripts": {
